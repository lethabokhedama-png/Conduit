# ── Conduit Engine — Environment Variables ────────────────────────────────────
# Copy to .env and fill in. Shared with gateway via docker-compose env_file.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_URL=postgres://conduit:conduit@localhost:5432/conduit

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ports ──────────────────────────────────────────────────────────────────────
ENGINE_PORT=8000

# ── Keepalive ──────────────────────────────────────────────────────────────────
# Public URL of this engine instance — pings /health every 14 min on free-tier.
# Leave blank to disable (fine for paid hosting that doesn't sleep).
SELF_URL=