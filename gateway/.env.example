# ── Conduit Gateway — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.
#
# Variable resolution priority (highest → lowest):
#   1. Shell environment / Docker env_file
#   2. This .env file
#   3. Defaults in conduit.config.toml (non-secret values only)

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# development | production | test

# Explicit version override — leave blank to resolve from git tag → package.json
CONDUIT_VERSION=

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_URL=postgres://conduit:conduit@localhost:5432/conduit

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_before_deploying_minimum_32_chars

# ── Provider API Keys ──────────────────────────────────────────────────────────
# Env fallbacks — UI-saved keys take priority. Leave blank to manage via UI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
STABILITY_API_KEY=
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=

# ── Ollama ─────────────────────────────────────────────────────────────────────
# No trailing slash. No # at the end.
OLLAMA_URL=http://localhost:11434

# ── Ports ──────────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
ENGINE_PORT=8000

# ── Keepalive ──────────────────────────────────────────────────────────────────
# Public URL — used by engine to ping /health every 14min on free-tier hosts.
SELF_URL=

# ── License (optional) ─────────────────────────────────────────────────────────
LICENSE_MANIFEST_URL=
LICENSE_PUBLIC_KEY=