# ── Conduit Gateway — Development Environment ─────────────────────────────────
# Local development defaults. Safe to commit — no real secrets here.
# Override anything by creating a .env file (gitignored) in the same directory.

NODE_ENV=development

POSTGRES_URL=postgres://conduit:conduit@localhost:5432/conduit
REDIS_URL=redis://localhost:6379

# Placeholder JWT — rotate before sharing or deploying
JWT_SECRET=dev_jwt_secret_do_not_use_in_production_replace_me

OLLAMA_URL=http://localhost:11434

GATEWAY_PORT=4000
ENGINE_PORT=8000

# Add real keys here locally — this file is gitignored if you rename it to .env
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
STABILITY_API_KEY=
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=