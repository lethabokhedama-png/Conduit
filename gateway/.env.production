# ── Conduit Gateway — Production Environment ──────────────────────────────────
# DO NOT commit this file with real values.
# Use your hosting platform's secret management to inject these at runtime:
#   - Render:     Environment → Secret Files or Environment Variables
#   - Docker:     --env-file or secrets: in compose
#   - Kubernetes: Secrets mounted as env vars
#
# ── Pre-deploy checklist ───────────────────────────────────────────────────────
# [ ] JWT_SECRET is a fresh 64-char hex string (not the dev placeholder)
# [ ] POSTGRES_URL points to a managed DB with TLS (sslmode=require)
# [ ] POSTGRES_URL password is not 'conduit' or any default
# [ ] REDIS_URL points to a managed Redis with AUTH if exposed
# [ ] OLLAMA_URL is removed or points to a secured internal endpoint
# [ ] SELF_URL is set to your actual public deployment URL
# [ ] LICENSE_MANIFEST_URL and LICENSE_PUBLIC_KEY are set if using version lock
# [ ] All provider keys are scoped to minimum required permissions
# [ ] NODE_ENV=production (disables config hot-reload and dev logging)

NODE_ENV=production

# Use internal networking URLs when running inside Docker / Kubernetes
POSTGRES_URL=postgres://conduit:CHANGE_ME@your-postgres-host:5432/conduit?sslmode=require
REDIS_URL=redis://:CHANGE_ME@your-redis-host:6379

# 64-char hex — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME

GATEWAY_PORT=4000
ENGINE_PORT=8000

# Your public deployment URL — no trailing slash
SELF_URL=https://your-conduit-deployment.example.com

# Provider keys — managed via UI preferred, env fallback acceptable
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
STABILITY_API_KEY=
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=

# Do not set OLLAMA_URL in production unless you have a secured Ollama instance
# OLLAMA_URL=

# License server (optional)
LICENSE_MANIFEST_URL=
LICENSE_PUBLIC_KEY=